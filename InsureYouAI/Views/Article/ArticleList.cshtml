@model List<Article>

@{
    ViewData["Title"] = "ArticleList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

@functions {
    string GetCategoryBadgeClass(string categoryName)
    {
        return categoryName switch
        {
            "Sağlık Sigortası" => "bg-success-subtle text-success",
            "Tamamlayıcı Sağlık Sigortası" => "bg-success-subtle text-success",
            "Trafik Sigortası" => "bg-warning-subtle text-warning",
            "Trafik Kaskosu" => "bg-warning-subtle text-warning",
            "Konut Sigortası" => "bg-primary-subtle text-primary",
            "DASK (Zorunlu Deprem Sigortası)" => "bg-danger-subtle text-danger",
            "Yurt Dışı Seyahat Sigortası" => "bg-info-subtle text-info",
            "Hayat Sigortası" => "bg-dark-subtle text-dark",
            "Eğitim Sigortası" => "bg-secondary-subtle text-secondary",
            _ => "bg-light text-dark"
        };
    }
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h4 class="fw-semibold text-primary mb-0">
                <i class="bi bi-journal-text me-1"></i> Makaleler
            </h4>

            <div class="position-relative" style="width:260px;">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                <input type="text"
                       class="form-control ps-5 rounded-pill shadow-sm"
                       placeholder="Makale ara...">
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-muted">#</th>
                        <th class="text-muted">Başlık</th>
                        <th class="text-muted">Kategori</th>
                        <th class="text-muted">Yazar</th>
                        <th class="text-muted">Tarih</th>
                        <th class="text-center text-muted">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr class="article-row">
                            <td>
                                <span class="text-muted small">@count</span>
                            </td>

                            <td class="fw-medium">
                                <i class="bi bi-file-earmark-text text-primary me-1"></i>
                                @item.Title
                            </td>

                            <td>
                                <span class="badge rounded-pill px-3 py-2
                                    @GetCategoryBadgeClass(item.Category.CategoryName)">
                                    @item.Category.CategoryName
                                </span>
                            </td>

                            <td class="text-muted">
                                @item.AppUser.Name @item.AppUser.Surname
                            </td>

                            <td class="text-muted small">
                                @item.CreatedDate.ToString("dd MMM yyyy")
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">

                                    <a href="/Blog/BlogDetail/@item.ArticleId"
                                       target="_blank"
                                       class="btn btn-sm btn-light text-primary">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    <a href="/Article/UpdateArticle/@item.ArticleId"
                                       class="btn btn-sm btn-light text-warning">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    <a href="/Article/DeleteArticle/@item.ArticleId"
                                       class="btn btn-sm btn-light text-danger">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- CTA -->
        <div class="d-flex gap-2 mt-4">
            <a href="/Article/CreateArticle/"
               class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-1"></i> Yeni Makale
            </a>

            <a href="/Article/CreateArticleWithOpenAI/"
               class="btn btn-outline-info rounded-pill px-4">
                <i class="bi bi-robot me-1"></i> Yapay Zeka ile Oluştur
            </a>
        </div>
    </div>
</div>

